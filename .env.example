# Raspberry Pi Configuration
# Copy this file to .env and update with your details

PI_HOST=192.168.X.XX
PI_USER=
APP_DIR=/home/pi/treadmill-controller

# Strava API credentials (optional)
# Register at: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# App URL (used for OAuth callback)
APP_URL=https://192.168.X.XX:3001

# OpenAI TTS for coaching (optional — coaching falls back to text without this)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
TTS_VOICE=nova

# A2DP speaker playback (optional — for playing coaching audio on treadmill speakers)
# Set to the PulseAudio sink name of your treadmill's Bluetooth Classic A2DP connection
# Find with: pactl list sinks short | grep bluez
A2DP_SINK=
